# Core storage
GYM_DATA_DIR=./data
GYM_DATABASE_PATH=./data/gym-video-logger.db
GYM_MAX_FILE_SIZE_BYTES=21474836480
GYM_MAX_SESSION_SIZE_BYTES=107374182400
GYM_UPLOAD_CONCURRENCY=2
GYM_FFMPEG_PATH=ffmpeg
GYM_FFPROBE_PATH=ffprobe
GYM_SEED_SAMPLE_DATA=true

# YouTube. Mock mode is the safe default for first-run development.
GYM_YOUTUBE_MOCK_MODE=true
GYM_YOUTUBE_PROCESSING_POLL_SECONDS=20
GYM_YOUTUBE_CLIENT_SECRET_PATH=./secrets/youtube-client-secret.json
GYM_YOUTUBE_TOKEN_PATH=./secrets/youtube-token.json
GYM_YOUTUBE_PRIVACY_STATUS=unlisted
GYM_YOUTUBE_TITLE_TEMPLATE={session_name} — {workout_date}
GYM_YOUTUBE_DESCRIPTION_TEMPLATE={notes}\n\n{chapters}

# Source clips and the stitched output are deleted only after YouTube finishes processing.
GYM_DELETE_ORIGINALS_AFTER_SUCCESS=true
GYM_DELETE_OUTPUT_AFTER_SUCCESS=true

# Remove camera setup and pickup time from each clip before it is stitched.
# Short clips always retain at least 3 seconds.
GYM_TRIM_START_SECONDS=5
GYM_TRIM_END_SECONDS=5

# Phone push notifications for the installed PWA. The VAPID key is generated locally.
GYM_WEB_PUSH_VAPID_PRIVATE_KEY_PATH=./data/web-push-vapid-private.pem
GYM_WEB_PUSH_CONTACT_EMAIL=mailto:you@example.com
